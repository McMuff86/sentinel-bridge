{
  "id": "sentinel-bridge",
  "name": "Sentinel Bridge",
  "version": "0.1.0",
  "description": "Multi-engine bridge: Claude Code CLI, Codex CLI, Grok API, Ollama for OpenClaw.",
  "main": "./dist/index.js",
  "type": "module",
  "enabledByDefault": false,
  "configSchema": {
    "type": "object",
    "description": "Matches src/plugin.ts SentinelBridgeConfig — engine options under engines.claude | engines.codex | engines.grok",
    "properties": {
      "defaultEngine": {
        "type": "string",
        "enum": ["claude", "codex", "grok", "ollama"],
        "default": "claude"
      },
      "defaultModel": {
        "type": "string",
        "description": "Model ref, e.g. claude/opus"
      },
      "defaultFallbackChain": {
        "type": "array",
        "items": { "type": "string", "enum": ["claude", "codex", "grok", "ollama"] },
        "description": "After primary, try these engines if start() fails. [] disables."
      },
      "maxConcurrentSessions": { "type": "number", "default": 5 },
      "sessionTTLMs": {
        "type": "number",
        "description": "Idle TTL in milliseconds"
      },
      "cleanupIntervalMs": {
        "type": "number",
        "description": "Expiry sweep interval in milliseconds"
      },
      "engines": {
        "type": "object",
        "properties": {
          "claude": {
            "type": "object",
            "properties": {
              "command": { "type": "string" },
              "args": { "type": "array", "items": { "type": "string" } },
              "defaultModel": { "type": "string" },
              "cwd": { "type": "string" },
              "env": { "type": "object" },
              "enabled": { "type": "boolean" }
            }
          },
          "codex": {
            "type": "object",
            "properties": {
              "command": { "type": "string" },
              "args": { "type": "array", "items": { "type": "string" } },
              "defaultModel": { "type": "string" },
              "cwd": { "type": "string" },
              "env": { "type": "object" },
              "enabled": { "type": "boolean" }
            }
          },
          "grok": {
            "type": "object",
            "properties": {
              "defaultModel": { "type": "string" },
              "apiKey": { "type": "string" },
              "baseUrl": { "type": "string" },
              "cwd": { "type": "string" },
              "env": { "type": "object" },
              "enabled": { "type": "boolean" }
            }
          },
          "ollama": {
            "type": "object",
            "properties": {
              "defaultModel": { "type": "string" },
              "baseUrl": { "type": "string" },
              "cwd": { "type": "string" },
              "env": { "type": "object" },
              "enabled": { "type": "boolean" }
            }
          }
        }
      }
    }
  },
  "capabilities": {
    "childProcess": true,
    "networkAccess": ["api.x.ai", "localhost"]
  },
  "contracts": {
    "tools": [
      "sb_session_start",
      "sb_session_send",
      "sb_session_stop",
      "sb_session_list",
      "sb_session_status",
      "sb_session_overview",
      "sb_engine_list",
      "sb_engine_status",
      "sb_model_route",
      "sb_cost_report",
      "sb_compact",
      "sb_session_events",
      "sb_session_cancel",
      "sb_context_set",
      "sb_context_get",
      "sb_context_list",
      "sb_context_clear",
      "sb_role_list",
      "sb_role_get",
      "sb_role_register",
      "sb_session_relay",
      "sb_session_broadcast",
      "sb_workflow_start",
      "sb_workflow_status",
      "sb_workflow_cancel",
      "sb_workflow_list",
      "sb_workflow_template",
      "sb_route_task",
      "sb_circuit_status",
      "sb_circuit_reset"
    ],
    "exports": {
      "activate": "activate"
    }
  }
}
