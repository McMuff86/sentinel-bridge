{
  "name": "sentinel-bridge",
  "version": "0.2.0",
  "description": "Multi-engine LLM orchestration: route prompts across Claude, Codex, Grok, and Ollama with DAG workflows, adaptive routing, and 33+ MCP tools",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrianmuff/sentinel-bridge.git"
  },
  "keywords": [
    "mcp",
    "llm",
    "multi-engine",
    "orchestration",
    "claude",
    "codex",
    "grok",
    "ollama",
    "workflow",
    "routing",
    "agent"
  ],
  "bin": {
    "sentinel-bridge-mcp": "./dist/mcp/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit -p tsconfig.json",
    "mcp": "node dist/mcp/index.js"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
